# Copy this file to .env.local and fill in real values.
# Never commit .env.local (it is gitignored).
#
# In production (Vercel etc.), set the same variables in the
# host's environment variable panel.

# ─── Resend (transactional email) ─────────────────────────────────
# Get a key from https://resend.com/api-keys
RESEND_API_KEY=

# Inbox that receives new lead notifications submitted through the
# /contact form. Use whichever address your team monitors.
CONTACT_EMAIL_TO=hello@demeloapps.com

# From address Resend sends as. While your custom domain is not yet
# verified in Resend, use the sandbox sender:
#   DeMelo Apps <onboarding@resend.dev>
# Once demeloapps.com is verified in Resend, switch to a custom one:
#   DeMelo Apps <leads@demeloapps.com>
CONTACT_EMAIL_FROM=DeMelo Apps <onboarding@resend.dev>

# Copy this file to .env.local and fill in real values.
# Never commit .env.local (it is gitignored).
#
# In production (Vercel etc.), set the same variables in the
# host's environment variable panel.

# ─── Resend (transactional email) ─────────────────────────────────
# Get a key from https://resend.com/api-keys
RESEND_API_KEY=

# Inbox that receives new lead notifications submitted through the
# /contact form. Use whichever address your team monitors.
CONTACT_EMAIL_TO=hello@demeloapps.com

# From address Resend sends as. Must come from a verified domain in
# Resend (https://resend.com/domains) to deliver to arbitrary
# recipients. The sandbox sender (DeMelo Apps <onboarding@resend.dev>)
# can only deliver to your own Resend account address and will return
# HTTP 400 for any other recipient.
CONTACT_EMAIL_FROM=Contact <contact@demeloapps.com>

# Resend template id used for the auto-reply that goes to the customer
# after they submit the form. Leave empty to skip the auto-reply (only
# the internal notification will be sent). Find or manage templates at
# https://resend.com/templates
CONTACT_TEMPLATE_ID=
